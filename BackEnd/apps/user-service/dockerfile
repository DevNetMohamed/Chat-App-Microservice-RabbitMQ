# ─────────────────────────────────────────────
#  user-service  Dockerfile
#  Build context: repo root  (docker-compose context: .)
# ─────────────────────────────────────────────
FROM node:22-bookworm AS build

WORKDIR /workspace

# ── Copy pre-installed dependencies from build context
COPY package*.json ./
COPY apps/user-service/package*.json ./apps/user-service/
COPY node_modules ./node_modules
COPY apps/user-service/node_modules ./apps/user-service/node_modules


# ── 3. Copy source then build
COPY src ./src
COPY apps/user-service ./apps/user-service

WORKDIR /workspace/apps/user-service
RUN npm run build

# ─────────────────────────────────────────────
FROM node:22-bookworm AS runtime

WORKDIR /workspace

COPY node_modules ./node_modules
COPY apps/user-service/node_modules ./apps/user-service/node_modules
COPY --from=build /workspace/dist ./dist

EXPOSE 3003

CMD ["node", "dist/apps/user-service/index.js"]