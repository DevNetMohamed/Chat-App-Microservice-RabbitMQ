# ─────────────────────────────────────────────
#  api-gateway  Dockerfile
#  Build context: repo root  (docker-compose context: .)
# ─────────────────────────────────────────────
FROM node:22-alpine AS build

WORKDIR /workspace

# ── 1. Install ONLY the service's own deps (avoids the broken root package.json)
COPY apps/api_Getaway/package*.json ./apps/api_Getaway/
WORKDIR /workspace/apps/api_Getaway
RUN npm install --no-audit --no-fund

# ── 2. Install shared-src deps that are missing from the service package.json
#       (amqplib, @upstash/redis, jsonwebtoken, multer, cloudinary, nodemailer)
#       Install into WORKSPACE root so tsc can find them at ../../node_modules
WORKDIR /workspace
RUN npm install --no-audit --no-fund \
    amqplib@^0.10.4 \
    "@upstash/redis@^1.38.0" \
    "jsonwebtoken@^9.0.3" \
    "multer@^2.2.0" \
    "multer-storage-cloudinary@^4.0.0" \
    "cloudinary@^1.41.3" \
    "nodemailer@^6.9.16" \
    "@types/amqplib@^0.10.8" \
    "@types/cors@^2.8.19" \
    "@types/jsonwebtoken@^9.0.10" \
    "@types/multer@^2.1.0" \
    "@types/nodemailer@^6.4.17" \
    "@types/express@^5.0.6" \
    "@types/node@^22.0.0" \
    "typescript@^5.7.0"

# ── 3. Copy source then build
COPY src ./src
COPY apps/api_Getaway ./apps/api_Getaway

WORKDIR /workspace/apps/api_Getaway
RUN npm run build

# ─────────────────────────────────────────────
FROM node:22-alpine AS runtime

WORKDIR /workspace

COPY --from=build /workspace/dist ./dist
COPY --from=build /workspace/node_modules ./node_modules
COPY --from=build /workspace/apps/api_Getaway/node_modules ./apps/api_Getaway/node_modules

EXPOSE 3000

CMD ["node", "dist/apps/api_Getaway/index.js"]