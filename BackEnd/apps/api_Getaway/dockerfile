FROM node:22-bookworm AS build

WORKDIR /workspace

COPY package*.json ./
COPY apps/api_Getaway/package*.json ./apps/api_Getaway/
COPY node_modules ./node_modules
COPY apps/api_Getaway/node_modules ./apps/api_Getaway/node_modules

# ── 3. Copy source then build
COPY src ./src
COPY apps/api_Getaway ./apps/api_Getaway

WORKDIR /workspace/apps/api_Getaway
RUN npm run build

# ─────────────────────────────────────────────────────
FROM node:22-bookworm AS runtime

WORKDIR /workspace

COPY node_modules ./node_modules
COPY apps/api_Getaway/node_modules ./apps/api_Getaway/node_modules
COPY --from=build /workspace/dist ./dist

EXPOSE 3000

CMD ["node", "dist/apps/api_Getaway/index.js"]