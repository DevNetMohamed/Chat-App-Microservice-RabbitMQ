{
  "compilerOptions": {
    "rootDir": "../../",
    "outDir": "../../dist",
    "module": "nodenext",
    "target": "esnext",
    "types": ["node", "express", "cors", "jsonwebtoken", "amqplib"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": [
    "../../src/**/*",
    "./**/*"
  ],
  "exclude": [
    "node_modules",
    "../../dist"
  ]
}
