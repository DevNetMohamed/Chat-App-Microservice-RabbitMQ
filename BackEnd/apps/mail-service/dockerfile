
FROM node:22-bookworm AS build

WORKDIR /workspace

COPY package*.json ./
COPY apps/mail-service/package*.json ./apps/mail-service/
COPY node_modules ./node_modules
COPY apps/mail-service/node_modules ./apps/mail-service/node_modules

# ── 3. Copy source then build
COPY src ./src
COPY apps/mail-service ./apps/mail-service

WORKDIR /workspace/apps/mail-service
RUN npm run build

# ─────────────────────────────────────────────
FROM node:22-bookworm AS runtime

WORKDIR /workspace

COPY node_modules ./node_modules
COPY apps/mail-service/node_modules ./apps/mail-service/node_modules
COPY --from=build /workspace/dist ./dist

EXPOSE 3002

CMD ["node", "dist/apps/mail-service/index.js"]